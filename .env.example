ANTHROPIC_API_KEY=your_anthropic_api_key_here
VOYAGE_API_KEY=your_voyage_api_key_here
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# ChromaDB connection (override if running ChromaDB outside Docker)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# CORS — comma-separated list of allowed frontend origins
# Default: http://localhost:3000 (no change needed for local dev)
# Example for Render: FRONTEND_URL=https://scoutlit.onrender.com,https://scoutlit-staging.onrender.com
FRONTEND_URL=http://localhost:3000
